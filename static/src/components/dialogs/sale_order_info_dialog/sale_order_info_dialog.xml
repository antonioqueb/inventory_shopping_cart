<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="inventory_shopping_cart.SaleOrderInfoDialog" owl="1">
        <Dialog size="'lg'">
            <div class="so-lot-popup isc-modal-surface">
                <button type="button"
                        class="isc-modal-close"
                        t-on-click="props.close"
                        title="Cerrar">
                    <i class="fa fa-times"></i>
                </button>

                <div class="so-lot-popup__header">
                    <div class="so-lot-popup__title-block">
                        <div class="so-lot-popup__eyebrow">Orden de Venta relacionada</div>

                        <h3>
                            <t t-if="hasOrder">
                                <t t-esc="info.sale_order_name"/>
                            </t>
                            <t t-else="">
                                Sin orden relacionada
                            </t>
                        </h3>

                        <p>
                            <strong t-esc="info.lot_name || '-'"/>
                            <span> · </span>
                            <span t-esc="info.product_name || '-'"/>
                        </p>
                    </div>

                    <span t-att-class="paymentBadgeClass">
                        <t t-esc="info.payment_label || 'Sin pago'"/>
                    </span>
                </div>

                <div class="so-lot-popup__grid">
                    <!-- Material -->
                    <section class="so-lot-card">
                        <h4>
                            <i class="fa fa-cube"></i>
                            Material
                        </h4>

                        <div class="so-info-row">
                            <span>Producto</span>
                            <strong t-esc="info.product_name || '-'"/>
                        </div>

                        <div class="so-info-row">
                            <span>Lote</span>
                            <strong t-esc="info.lot_name || '-'"/>
                        </div>

                        <div class="so-info-row">
                            <span>Cantidad</span>
                            <strong>
                                <t t-esc="formatNumber(info.quantity)"/>
                                <t t-esc="info.uom || 'm²'"/>
                            </strong>
                        </div>

                        <div class="so-info-row">
                            <span>Ubicación</span>
                            <strong t-esc="info.location_name || '-'"/>
                        </div>

                        <div class="so-info-row so-info-row--eta"
                             t-if="info.is_transit and info.eta">
                            <span>ETA</span>
                            <strong t-esc="info.eta"/>
                        </div>
                    </section>

                    <!-- Orden comercial -->
                    <section class="so-lot-card">
                        <h4>
                            <i class="fa fa-file-text"></i>
                            Orden comercial
                        </h4>

                        <div class="so-info-row">
                            <span>Orden</span>
                            <strong t-esc="info.sale_order_name || '-'"/>
                        </div>

                        <div class="so-info-row">
                            <span>Cliente</span>
                            <strong t-esc="info.partner_name || '-'"/>
                        </div>

                        <div class="so-info-row">
                            <span>Vendedor</span>
                            <strong t-esc="info.seller_name || '-'"/>
                        </div>

                        <button class="btn btn-primary so-open-order-btn"
                                t-if="hasOrder"
                                t-on-click="openSaleOrder">
                            <i class="fa fa-external-link"></i>
                            Abrir orden
                        </button>
                    </section>

                    <!-- Pago -->
                    <section class="so-lot-card so-payment-card">
                        <h4>
                            <i class="fa fa-credit-card"></i>
                            Pago
                        </h4>

                        <div class="so-payment-percent">
                            <strong>
                                <t t-esc="formatNumber(info.paid_percentage || 0)"/>%
                            </strong>
                            <span>pagado</span>
                        </div>

                        <div class="so-info-row">
                            <span>Monto pagado</span>
                            <strong t-esc="formatCurrency(info.amount_paid)"/>
                        </div>

                        <div class="so-info-row">
                            <span>Total de la orden</span>
                            <strong t-esc="formatCurrency(info.amount_total)"/>
                        </div>

                        <div class="so-info-row so-info-row--pending">
                            <span>Saldo pendiente</span>
                            <strong t-esc="formatCurrency(info.amount_residual)"/>
                        </div>
                    </section>
                </div>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-light border"
                        t-on-click="props.close">
                    Cerrar
                </button>

                <button class="btn btn-primary"
                        t-if="hasOrder"
                        t-on-click="openSaleOrder">
                    <i class="fa fa-external-link"></i>
                    Abrir orden
                </button>
            </t>
        </Dialog>
    </t>

</templates>