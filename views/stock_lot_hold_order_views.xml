<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_lot_hold_order_tree_manual_pricing" model="ir.ui.view">
        <field name="name">stock.lot.hold.order.list.manual.pricing</field>
        <field name="model">stock.lot.hold.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="arquitecto_id"/>
                <field name="user_id"/>
                <field name="fecha_orden"/>
                <field name="fecha_expiracion"/>
                <field name="x_hold_business_days" string="Días hábiles"/>
                <field name="x_days_to_expiration" string="Días restantes"/>
                <field name="currency_id"/>
                <field name="x_total_m2" string="m²"/>
                <field name="x_amount_total" string="Total" widget="monetary"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_stock_lot_hold_order_form_manual_pricing" model="ir.ui.view">
        <field name="name">stock.lot.hold.order.form.manual.pricing</field>
        <field name="model">stock.lot.hold.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Apartado / Reservación">
                <header>
                    <button name="action_recompute_hold_lines"
                            string="Recalcular"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"/>

                    <button name="action_confirm"
                            string="Confirmar Apartado"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['draft', 'borrador']"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <style>
                        .o_form_view .o_hold_order_lines_pricing {
                            width: 100% !important;
                            overflow-x: hidden !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing .o_list_renderer,
                        .o_form_view .o_hold_order_lines_pricing .o_list_view,
                        .o_form_view .o_hold_order_lines_pricing .table-responsive {
                            width: 100% !important;
                            overflow-x: hidden !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table {
                            width: 100% !important;
                            table-layout: fixed !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table thead th {
                            position: relative !important;
                            top: auto !important;
                            z-index: 2 !important;
                            height: 44px !important;
                            padding: 10px 8px !important;
                            vertical-align: middle !important;
                            white-space: nowrap !important;
                            overflow: hidden !important;
                            text-overflow: ellipsis !important;
                            background: #ffffff !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table tbody td {
                            padding: 8px 8px !important;
                            vertical-align: middle !important;
                            overflow: hidden !important;
                            text-overflow: ellipsis !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table th[data-name="product_id"],
                        .o_form_view .o_hold_order_lines_pricing table.o_list_table td[name="product_id"] {
                            width: 25% !important;
                            max-width: 25% !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table th[data-name="lot_ids"],
                        .o_form_view .o_hold_order_lines_pricing table.o_list_table td[name="lot_ids"] {
                            width: 25% !important;
                            max-width: 25% !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table th[data-name="cantidad_m2"],
                        .o_form_view .o_hold_order_lines_pricing table.o_list_table td[name="cantidad_m2"] {
                            width: 8% !important;
                            max-width: 8% !important;
                            text-align: right !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table th[data-name="x_price_selector"],
                        .o_form_view .o_hold_order_lines_pricing table.o_list_table td[name="x_price_selector"] {
                            width: 19% !important;
                            max-width: 19% !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table th[data-name="precio_unitario"],
                        .o_form_view .o_hold_order_lines_pricing table.o_list_table td[name="precio_unitario"] {
                            width: 11% !important;
                            max-width: 11% !important;
                            text-align: right !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing table.o_list_table th[data-name="x_subtotal"],
                        .o_form_view .o_hold_order_lines_pricing table.o_list_table td[name="x_subtotal"] {
                            width: 12% !important;
                            max-width: 12% !important;
                            text-align: right !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing .o_field_many2one,
                        .o_form_view .o_hold_order_lines_pricing .o_field_many2many_tags,
                        .o_form_view .o_hold_order_lines_pricing .o_price_level_selector,
                        .o_form_view .o_hold_order_lines_pricing .o_price_level_selector__select {
                            width: 100% !important;
                            min-width: 0 !important;
                            max-width: 100% !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing .o_price_level_selector__select {
                            height: 34px !important;
                            padding: 4px 8px !important;
                        }

                        .o_form_view .o_hold_order_lines_pricing .o_field_many2many_tags .badge,
                        .o_form_view .o_hold_order_lines_pricing .o_field_many2many_tags .o_tag {
                            max-width: 100% !important;
                            overflow: hidden !important;
                            text-overflow: ellipsis !important;
                        }
                    </style>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Cliente">
                            <field name="partner_id" string="Cliente" required="1"/>
                            <field name="delivery_address" string="Dirección de Entrega" placeholder="Dirección de entrega..."/>
                            <field name="project_id" string="Proyecto"/>
                            <field name="arquitecto_id" string="Arquitecto"/>
                        </group>

                        <group string="Información">
                            <field name="user_id" string="Vendedor" readonly="1"/>
                            <field name="fecha_orden" string="Fecha de Orden" readonly="1" force_save="1"/>
                            <field name="fecha_expiracion" string="Fecha de Expiración" readonly="1" force_save="1"/>
                            <field name="x_days_to_expiration" string="Días Restantes" readonly="1"/>
                            <field name="currency_id" string="Moneda" required="1"/>

                            <separator/>

                            <field name="x_hold_business_days"
                                   string="Días hábiles"
                                   readonly="1"
                                   force_save="1"/>

                            <field name="x_total_m2"
                                   string="Total m²"
                                   readonly="1"/>

                            <field name="x_amount_total"
                                   string="Total General"
                                   widget="monetary"
                                   readonly="1"/>
                        </group>
                    </group>

                    <div class="alert alert-info" role="status">
                        <strong>Regla comercial:</strong>
                        el apartado manual usa la escalera comercial del producto.
                        Los vendedores ven <strong>Precio 1</strong>, <strong>Precio 2</strong> y pueden usar
                        <strong>Precio Personalizado</strong>. Si el precio personalizado queda debajo de
                        <strong>Precio 2</strong>, se genera solicitud de autorización.
                        Los autorizadores pueden ver <strong>Precio 3</strong>.
                    </div>

                    <notebook>
                        <page string="Placas Reservadas">
                            <field name="line_ids"
                                   nolabel="1"
                                   class="o_hold_order_lines_pricing"
                                   context="{'default_order_id': id, 'default_currency_id': currency_id}">
                                <list editable="bottom">
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="x_price_1_value" column_invisible="1"/>
                                    <field name="x_price_2_value" column_invisible="1"/>
                                    <field name="x_price_3_value" column_invisible="1"/>
                                    <field name="x_price_level_currency" column_invisible="1"/>
                                    <field name="x_can_use_custom_price" column_invisible="1"/>
                                    <field name="x_can_use_minimum_price" column_invisible="1"/>
                                    <field name="lot_id" column_invisible="1"/>
                                    <field name="quant_id" column_invisible="1"/>

                                    <field name="product_id"
                                           string="Producto"
                                           required="1"
                                           width="25%"/>

                                    <field name="lot_ids"
                                           string="Placas"
                                           widget="many2many_tags"
                                           width="25%"/>

                                    <field name="cantidad_m2"
                                           string="m²"
                                           force_save="1"
                                           width="8%"/>

                                    <field name="x_price_selector"
                                           string="Nivel de Precio"
                                           widget="price_level_selector"
                                           required="1"
                                           width="19%"/>

                                    <field name="precio_unitario"
                                           string="Precio/m²"
                                           readonly="x_price_selector != 'custom' or not x_can_use_custom_price"
                                           force_save="1"
                                           width="11%"/>

                                    <field name="x_subtotal"
                                           string="Total"
                                           widget="monetary"
                                           readonly="1"
                                           width="12%"/>
                                </list>

                                <form>
                                    <group>
                                        <group string="Material">
                                            <field name="product_id" required="1"/>
                                            <field name="lot_ids" widget="many2many_tags"/>
                                            <field name="lot_id"/>
                                            <field name="quant_id"/>
                                            <field name="cantidad_m2" string="m²" force_save="1"/>
                                        </group>

                                        <group string="Precio">
                                            <field name="currency_id" invisible="1"/>
                                            <field name="x_price_1_value" invisible="1"/>
                                            <field name="x_price_2_value" invisible="1"/>
                                            <field name="x_price_3_value" invisible="1"/>
                                            <field name="x_price_level_currency" invisible="1"/>
                                            <field name="x_can_use_custom_price" invisible="1"/>
                                            <field name="x_can_use_minimum_price" invisible="1"/>

                                            <field name="x_price_selector"
                                                   string="Nivel de Precio"
                                                   widget="price_level_selector"
                                                   required="1"/>

                                            <field name="precio_unitario"
                                                   string="Precio/m²"
                                                   readonly="x_price_selector != 'custom' or not x_can_use_custom_price"
                                                   force_save="1"/>

                                            <field name="x_subtotal"
                                                   string="Total"
                                                   widget="monetary"
                                                   readonly="1"/>
                                        </group>
                                    </group>
                                </form>
                            </field>

                            <group class="oe_subtotal_footer">
                                <field name="x_total_m2"
                                       readonly="1"
                                       string="Total m²"/>

                                <field name="x_amount_total"
                                       readonly="1"
                                       widget="monetary"
                                       string="Total Apartado"/>
                            </group>
                        </page>

                        <page string="Notas">
                            <field name="notas" placeholder="Observaciones del apartado..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_stock_lot_hold_order_manual_pricing" model="ir.actions.act_window">
        <field name="name">Apartados / Reservaciones</field>
        <field name="res_model">stock.lot.hold.order</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[
            (ref('inventory_shopping_cart.view_stock_lot_hold_order_tree_manual_pricing'), 'list'),
            (ref('inventory_shopping_cart.view_stock_lot_hold_order_form_manual_pricing'), 'form')
        ]"/>
        <field name="context">{'default_currency_id': ref('base.USD'), 'default_x_hold_business_days': 5}</field>
    </record>

    <menuitem id="menu_stock_lot_hold_order_manual_pricing"
              name="Apartados / Reservaciones"
              parent="sale.sale_menu_root"
              action="action_stock_lot_hold_order_manual_pricing"
              groups="inventory_shopping_cart.group_seller,inventory_shopping_cart.group_price_authorizer"
              sequence="36"/>

</odoo>