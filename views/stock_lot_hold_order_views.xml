<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_lot_hold_order_tree_manual_pricing" model="ir.ui.view">
        <field name="name">stock.lot.hold.order.list.manual.pricing</field>
        <field name="model">stock.lot.hold.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="fecha_orden"/>
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="arquitecto_id"/>
                <field name="user_id"/>
                <field name="currency_id"/>
                <field name="total_placas" string="Placas"/>
                <field name="total_m2" string="m²"/>
                <field name="total_con_precio" string="Total" widget="monetary"/>
                <field name="fecha_expiracion"/>
                <field name="dias_restantes"
                       string="Días restantes"
                       decoration-danger="dias_restantes &lt;= 2"
                       decoration-warning="dias_restantes &lt;= 5 and dias_restantes &gt; 2"/>
                <field name="sale_order_id" optional="hide"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_stock_lot_hold_order_form_manual_pricing" model="ir.ui.view">
        <field name="name">stock.lot.hold.order.form.manual.pricing</field>
        <field name="model">stock.lot.hold.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Apartado / Reservación">
                <header>
                    <button name="action_recompute_hold_lines"
                            string="Recalcular"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"
                            invisible="state in ['done', 'cancel']"/>

                    <button name="action_confirm"
                            string="Confirmar Reserva"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['draft', 'borrador']"/>

                    <button name="action_convert_to_sale_order"
                            string="Crear SO"
                            type="object"
                            class="btn-success"
                            invisible="state != 'confirmed' or sale_order_id"
                            confirm="¿Convertir esta reserva en orden de venta?"/>

                    <button name="action_renew"
                            string="Renovar 5 Días"
                            type="object"
                            class="btn-warning"
                            invisible="state != 'confirmed' or sale_order_id or not x_can_renew"/>

                    <button name="action_done"
                            string="Finalizar"
                            type="object"
                            invisible="state != 'confirmed' or sale_order_id"/>

                    <button name="action_cancel"
                            string="Cancelar"
                            type="object"
                            invisible="state in ['done', 'cancel']"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancel"/>
                </header>

                <sheet>
                    <field name="sale_order_id" invisible="1"/>
                    <field name="x_can_renew" invisible="1"/>

                    <div class="oe_button_box" name="button_box">
                        <button name="%(sale.act_res_partner_2_sale_order)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible="not sale_order_id"
                                context="{'search_default_order_id': sale_order_id}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Ver</span>
                                <span class="o_stat_text">Orden de Venta</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Cliente">
                            <field name="partner_id" string="Cliente" required="1"/>
                            <field name="available_delivery_partner_ids" invisible="1"/>
                            <field name="delivery_partner_id"
                                   string="Contacto de Entrega"
                                   invisible="not available_delivery_partner_ids"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="delivery_address"
                                   string="Dirección de Entrega"
                                   placeholder="Dirección de entrega..."/>
                            <field name="project_id" string="Proyecto"/>
                            <field name="arquitecto_id" string="Arquitecto"/>
                        </group>

                        <group string="Configuración">
                            <field name="currency_id" string="Moneda" required="1"/>
                        </group>
                    </group>

                    <!-- ===================================================== -->
                    <!-- Campos NO editables (automáticos/calculados): se      -->
                    <!-- mantienen en la vista como invisibles para conservar  -->
                    <!-- sus valores, force_save y cálculos, pero no se        -->
                    <!-- muestran. Los totales siguen visibles en el pie de    -->
                    <!-- las líneas (página "Placas Reservadas").              -->
                    <!-- ===================================================== -->
                    <group invisible="1">
                        <field name="user_id" readonly="1"/>
                        <field name="fecha_orden" readonly="1" force_save="1"/>
                        <field name="fecha_expiracion" readonly="1" force_save="1"/>
                        <field name="dias_restantes" readonly="1"/>
                        <field name="x_hold_business_days" readonly="1" force_save="1"/>
                        <field name="total_placas" readonly="1"/>
                        <field name="total_m2" readonly="1"/>
                        <field name="total_con_precio" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Placas Reservadas">
                            <field name="hold_line_ids"
                                   nolabel="1"
                                   context="{
                                       'default_order_id': id,
                                       'default_currency_id': currency_id
                                   }">
                                <list editable="bottom">
                                    <!-- Campos técnicos de precio -->
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="x_price_1_value" column_invisible="1"/>
                                    <field name="x_price_2_value" column_invisible="1"/>
                                    <field name="x_price_3_value" column_invisible="1"/>
                                    <field name="x_price_4_value" column_invisible="1"/>
                                    <field name="x_price_5_value" column_invisible="1"/>
                                    <field name="x_price_level_currency" column_invisible="1"/>
                                    <field name="x_can_use_custom_price" column_invisible="1"/>
                                    <field name="x_can_use_minimum_price" column_invisible="1"/>

                                    <!-- Selector visual existente de stock_lot_dimensions.
                                         Este es el widget correcto, no hold_stone_expand_button. -->
                                    <field name="lot_ids"
                                           widget="hold_stone_button"
                                           string=" "
                                           width="30px"
                                           nolabel="1"
                                           class="p-0 text-center"/>

                                    <field name="product_id"
                                           string="Producto"
                                           required="1"
                                           context="{'hold_hide_services_default': 1}"/>

                                    <!-- Contador de placas: oculto como columna pero se
                                         mantiene en la vista porque 'm²' lo usa en su
                                         modificador readonly. -->
                                    <field name="lot_count" column_invisible="1"/>

                                    <field name="cantidad_m2"
                                           string="Cantidad"
                                           readonly="lot_count != 0"
                                           force_save="1"/>

                                    <field name="product_uom_id"
                                           string="Unidad de Medida"/>

                                    <field name="x_price_selector"
                                           string="Nivel de Precio"
                                           widget="price_level_selector"
                                           required="1"/>

                                    <field name="precio_unitario"
                                           string="Precio/m²"
                                           readonly="x_price_selector != 'custom'"
                                           force_save="1"/>

                                    <field name="precio_total"
                                           string="Total"
                                           widget="monetary"
                                           readonly="1"/>

                                    <field name="x_tax_amount"
                                           string="Impuestos"
                                           widget="monetary"
                                           readonly="1"/>

                                    <!-- Campos técnicos / legacy -->
                                    <field name="lot_ids" column_invisible="1"/>
                                    <field name="lot_id" column_invisible="1"/>
                                    <field name="quant_id" column_invisible="1"/>
                                    <field name="hold_ids" column_invisible="1"/>
                                    <field name="hold_id" column_invisible="1"/>
                                </list>

                                <form>
                                    <group>
                                        <group string="Material">
                                            <field name="product_id" required="1"
                                                   context="{'hold_hide_services_default': 1}"/>

                                            <field name="lot_ids"
                                                   widget="hold_stone_button"
                                                   string="Placas"/>

                                            <field name="lot_count"
                                                   string="Placas"
                                                   readonly="1"/>

                                            <field name="cantidad_m2"
                                                   string="Cantidad"
                                                   readonly="lot_count != 0"
                                                   force_save="1"/>

                                            <field name="product_uom_id"
                                                   string="Unidad de Medida"/>

                                            <field name="lot_id" invisible="1"/>
                                            <field name="quant_id" invisible="1"/>
                                            <field name="hold_ids" invisible="1"/>
                                            <field name="hold_id" invisible="1"/>
                                        </group>

                                        <group string="Precio">
                                            <field name="currency_id" invisible="1"/>
                                            <field name="x_price_1_value" invisible="1"/>
                                            <field name="x_price_2_value" invisible="1"/>
                                            <field name="x_price_3_value" invisible="1"/>
                                            <field name="x_price_4_value" invisible="1"/>
                                            <field name="x_price_5_value" invisible="1"/>
                                            <field name="x_price_level_currency" invisible="1"/>
                                            <field name="x_can_use_custom_price" invisible="1"/>
                                            <field name="x_can_use_minimum_price" invisible="1"/>

                                            <field name="x_price_selector"
                                                   string="Nivel de Precio"
                                                   widget="price_level_selector"
                                                   required="1"/>

                                            <field name="precio_unitario"
                                                   string="Precio/m²"
                                                   readonly="x_price_selector != 'custom'"
                                                   force_save="1"/>

                                            <field name="precio_total"
                                                   string="Total"
                                                   widget="monetary"
                                                   readonly="1"/>

                                            <field name="x_tax_amount"
                                                   string="Impuestos"
                                                   widget="monetary"
                                                   readonly="1"/>
                                        </group>
                                    </group>
                                </form>
                            </field>

                            <group class="oe_subtotal_footer">
                                <field name="x_amount_total"
                                       string="Subtotal"
                                       widget="monetary"
                                       readonly="1"/>

                                <field name="x_amount_tax"
                                       string="Impuestos"
                                       widget="monetary"
                                       readonly="1"/>

                                <field name="x_amount_total_taxed"
                                       string="Total $"
                                       widget="monetary"
                                       readonly="1"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>

                        <page string="Notas">
                            <field name="notas" placeholder="Observaciones del apartado..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_stock_lot_hold_order_manual_pricing" model="ir.actions.act_window">
        <field name="name">Apartados / Reservaciones</field>
        <field name="res_model">stock.lot.hold.order</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[
            (ref('inventory_shopping_cart.view_stock_lot_hold_order_tree_manual_pricing'), 'list'),
            (ref('inventory_shopping_cart.view_stock_lot_hold_order_form_manual_pricing'), 'form')
        ]"/>
        <field name="context">{'default_currency_id': ref('base.USD'), 'default_x_hold_business_days': 5}</field>
    </record>

</odoo>