<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_enhanced_prices" model="ir.ui.view">
        <field name="name">sale.order.form.enhanced.prices</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- ===================== HEADER BUTTONS ===================== -->
            <xpath expr="//header" position="inside">
                <button name="action_add_from_cart"
                    string="📥 Agregar desde Carrito"
                    type="object"
                    class="btn-secondary"
                    invisible="state not in ['draft', 'sent']"
                    groups="base.group_user"
                    help="Agrega los productos que tengas actualmente en tu carrito visual a esta orden."/>
                <button name="action_request_authorization"
                    string="Solicitar Autorización de Precio"
                    type="object"
                    class="btn-warning"
                    invisible="state not in ['draft', 'sent'] or x_price_authorization_id"
                    groups="inventory_shopping_cart.group_seller"/>
            </xpath>

            <!-- ===================== OCULTAR BOTONES CUANDO HAY PRECIOS BAJOS ===================== -->
            <xpath expr="//header/button[@name='action_quotation_send']" position="attributes">
                <attribute name="invisible">state not in ['draft', 'sent'] or x_has_low_prices</attribute>
            </xpath>

            <xpath expr="//header/button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">state not in ['draft', 'sent'] or x_has_low_prices</attribute>
            </xpath>

            <!-- ===================== BANNER ROJO ALARMANTE ===================== -->
            <xpath expr="//sheet" position="before">
                <field name="x_has_low_prices" invisible="1"/>

                <div class="alert alert-danger text-center" role="alert" style="font-size: 1.1em; border: 3px solid #dc3545; background-color: #f8d7da;"
                     invisible="not x_has_low_prices or state not in ['draft', 'sent']"
                     groups="inventory_shopping_cart.group_seller">
                    <i class="fa fa-ban fa-2x mb-2" title="Orden bloqueada" style="display: block; color: #dc3545;"></i>
                    <strong style="font-size: 1.3em; color: #721c24;">🚫 ORDEN BLOQUEADA - PRECIOS NO AUTORIZADOS</strong>
                    <br/>
                    <span style="color: #721c24;">
                        Esta cotización tiene productos con precio por debajo del nivel medio permitido.
                        <br/>
                        <strong>No puede enviar, imprimir ni confirmar esta orden.</strong>
                        <br/>
                        Use el botón "Solicitar Autorización de Precio" para continuar.
                    </span>
                </div>

                <div class="alert alert-warning text-center" role="alert"
                     invisible="not x_has_low_prices or state not in ['draft', 'sent']"
                     groups="inventory_shopping_cart.group_price_authorizer">
                    <i class="fa fa-info-circle me-2" title="Información de precios"></i>
                    <strong>Nota:</strong> Esta cotización tiene precios por debajo del nivel medio. Como autorizador, puede continuar sin restricción.
                </div>
            </xpath>

            <!-- ===================== COLUMNA DERECHA (partner_details) ===================== -->
            <xpath expr="//group[@name='partner_details']" position="inside">
                <field name="partner_invoice_id"
                    string="Dirección de Facturación"
                    required="0"
                    context="{'default_parent_id': partner_id, 'default_type': 'invoice', 'show_address': 1}"
                    options='{"always_reload": True, "no_create": False}'
                    domain="['|', '&amp;', ('parent_id', '=', partner_id), ('type', '=', 'invoice'), ('id', '=', partner_id)]"/>
                <field name="partner_shipping_id"
                    string="Dirección de Entrega"
                    required="0"
                    context="{'default_parent_id': partner_id, 'default_type': 'delivery', 'show_address': 1}"
                    options='{"always_reload": True, "no_create": False}'
                    domain="['|', '&amp;', ('parent_id', '=', partner_id), ('type', '=', 'delivery'), ('id', '=', partner_id)]"/>
                <field name="x_project_id" string="Job Name / Proyecto"/>
                <field name="x_architect_id"
                     string="Arquitecto"
                    domain="[('x_es_arquitecto', '=', True)]"/>
            </xpath>

            <!-- ===================== COLUMNA IZQUIERDA (order_details) ===================== -->
            <xpath expr="//group[@name='order_details']/field[@name='payment_term_id']" position="after">
                <field name="x_price_authorization_id"
                    string="Autorización de Precio"
                    readonly="1"
                    invisible="not x_price_authorization_id"/>

                <field name="x_is_usd" invisible="1"/>
                <field name="x_exchange_rate_source"
                     string="Fuente TC"
                    invisible="not x_is_usd"/>
                <field name="x_exchange_rate"
                     string="Tipo de Cambio MXN/USD"
                    readonly="1"
                    invisible="not x_is_usd"/>
            </xpath>

            <!-- ===================== ORDER LINES: PRICE SELECTOR ===================== -->
            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']" position="before">
                <field name="x_price_selector"
                    optional="show"
                    style="width: 140px;"
                    required="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']" position="attributes">
                <attribute name="readonly">x_price_selector != 'custom'</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

        </field>
    </record>

    <!-- ============================================================
         Vista Tree: Órdenes de Venta - Columna Job Name/Proyecto
         ============================================================ -->
    <record id="view_order_tree_project_column" model="ir.ui.view">
        <field name="name">sale.order.tree.project.column</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="x_project_id" string="Job Name/Proyecto" optional="show"/>
            </field>
        </field>
    </record>

    <!-- ============================================================
         Vista Tree: Presupuestos - Columna Job Name/Proyecto
         ============================================================ -->
    <record id="view_quotation_tree_project_column" model="ir.ui.view">
        <field name="name">sale.order.quotation.tree.project.column</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="x_project_id" string="Job Name/Proyecto" optional="show"/>
            </field>
        </field>
    </record>

</odoo>