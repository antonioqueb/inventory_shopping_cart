<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Vista Form: Sale Order - Enhanced Prices & Custom Fields

         Distribución de columnas:
         ─────────────────────────────────────────────────────────
         IZQUIERDA (order_details)     │  DERECHA (partner_details)
         ─────────────────────────────────────────────────────────
         1. Vencimiento                │  1. Cliente
         2. CFDI público en general    │  2. Dir. Facturación *
         3. Forma de pago              │  3. Dir. Envío *
         4. Política de pago           │  4. Job Name / Proyecto
         5. Uso                        │  5. Arquitecto
         6. Fecha de cotización        │
         7. Lista de precios           │  (* solo con grupo delivery_invoice_address)
         8. Términos de pago           │
         9. Autorización de Precio **  │
         ─────────────────────────────────────────────────────────
         ** solo visible cuando existe autorización
         ============================================================ -->
    <record id="view_order_form_enhanced_prices" model="ir.ui.view">
        <field name="name">sale.order.form.enhanced.prices</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- ===================== HEADER BUTTONS ===================== -->
            <xpath expr="//header" position="inside">
                <button name="action_add_from_cart"
                    string="📥 Agregar desde Carrito"
                    type="object"
                    class="btn-secondary"
                    invisible="state not in ['draft', 'sent']"
                    groups="base.group_user"
                    help="Agrega los productos que tengas actualmente en tu carrito visual a esta orden."/>
                <button name="action_request_authorization"
                    string="Solicitar Autorización de Precio"
                    type="object"
                    class="btn-warning"
                    invisible="state not in ['draft', 'sent'] or x_price_authorization_id"
                    groups="base.group_user"/>
            </xpath>

            <!-- ===================== COLUMNA DERECHA (partner_details) ===================== -->
            <!-- Campos 4 y 5: Proyecto y Arquitecto debajo de Cliente/Direcciones -->
            <xpath expr="//group[@name='partner_details']" position="inside">
                <field name="x_project_id" string="Job Name / Proyecto"/>
                <field name="x_architect_id" string="Arquitecto"/>
            </xpath>

            <!-- ===================== COLUMNA IZQUIERDA (order_details) ===================== -->
            <!-- Campo 9: Autorización de Precio al final de la columna izquierda -->
            <xpath expr="//group[@name='order_details']/field[@name='payment_term_id']" position="after">
                <field name="x_price_authorization_id"
                    string="Autorización de Precio"
                    readonly="1"
                    invisible="not x_price_authorization_id"/>
            </xpath>

            <!-- ===================== ORDER LINES: PRICE SELECTOR ===================== -->
            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']" position="before">
                <field name="x_price_selector"
                    optional="show"
                    style="width: 140px;"
                    required="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']" position="attributes">
                <attribute name="readonly">x_price_selector != 'custom'</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

        </field>
    </record>

    <!-- ============================================================
         Vista Tree: Órdenes de Venta - Columna Job Name/Proyecto
         ============================================================ -->
    <record id="view_order_tree_project_column" model="ir.ui.view">
        <field name="name">sale.order.tree.project.column</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="x_project_id" string="Job Name/Proyecto" optional="show"/>
            </field>
        </field>
    </record>

    <!-- ============================================================
         Vista Tree: Presupuestos - Columna Job Name/Proyecto
         ============================================================ -->
    <record id="view_quotation_tree_project_column" model="ir.ui.view">
        <field name="name">sale.order.quotation.tree.project.column</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="x_project_id" string="Job Name/Proyecto" optional="show"/>
            </field>
        </field>
    </record>

</odoo>